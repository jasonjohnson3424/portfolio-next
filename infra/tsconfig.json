{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "outDir": "dist"
  },
  "include": ["bin/**/*", "lib/**/*"],
  "exclude": ["node_modules", "dist"]
}
